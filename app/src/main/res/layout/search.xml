<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#0A0A10"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear4"
		android:layout_width="match_parent"
		android:layout_height="64dp"
		android:paddingLeft="16dp"
		android:paddingRight="16dp"
		android:gravity="center_vertical"
		android:orientation="horizontal">
		<LinearLayout
			android:id="@+id/btn_back_search"
			android:layout_width="40dp"
			android:layout_height="40dp"
			android:gravity="center_horizontal|center_vertical">
			<TextView
				android:id="@+id/textview16"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="←"
				android:textSize="24sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear5"
			android:layout_width="0dp"
			android:layout_height="40dp"
			android:layout_marginLeft="10dp"
			android:paddingLeft="14dp"
			android:paddingRight="14dp"
			android:background="#1E1E2E"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:layout_weight="1">
			<EditText
				android:id="@+id/edit_search_input"
				android:layout_width="0dp"
				android:layout_height="match_parent"
				android:textSize="14sp"
				android:textColor="#FFFFFF"
				android:hint="Type to search auto-suggest..."
				android:textColorHint="#555570"
				android:singleLine="true"
				android:imeOptions="actionSearch"
				android:layout_weight="1"
				android:background="@null" />
		</LinearLayout>
	</LinearLayout>
	<TextView
		android:id="@+id/tv_search_status"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="16dp"
		android:text="Type 3 or more letters..."
		android:textSize="14sp"
		android:textColor="#AAAAAA" />
	<ScrollView
		android:id="@+id/scroll_search"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:fillViewport="true">
		<LinearLayout
			android:id="@+id/linear6"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/grid_container"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical" />
			<TextView
				android:id="@+id/btn_load_more"
				android:layout_width="match_parent"
				android:layout_height="48dp"
				android:layout_marginTop="16dp"
				android:layout_marginBottom="24dp"
				android:background="#1A1A2E"
				android:gravity="center_horizontal|center_vertical"
				android:text="Load More"
				android:textSize="14sp"
				android:textColor="#00E676"
				android:visibility="gone" />
		</LinearLayout>
	</ScrollView>
</LinearLayout>
